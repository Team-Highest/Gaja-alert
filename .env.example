# Copy to .env and fill in real values. .env is gitignored — never commit it.

# Sarvam MCP (translation + TTS for alerts)
SARVAM_API_KEY=

# LLM endpoints (override gaja.json / gaja/config.py defaults)
GAJA_VISION_LLM_BASE=http://127.0.0.1:8081
GAJA_TEXT_LLM_BASE=http://127.0.0.1:8081
GAJA_TOOL_LLM_BASE=http://127.0.0.1:8081

# Optional when the Qualcomm assets are stored elsewhere
# GAJA_QWEN_NPU_BUNDLE=C:\path\to\qwen3_vl_4b_instruct-geniex_qairt-w4a16-qualcomm_snapdragon_x_elite
# QAIRT_HOME=C:\path\to\qairt\2.48.0.260626

# Network ports
GAJA_SENSOR_PORT=9000
GAJA_ALERT_PORT=9001
GAJA_DASHBOARD_PORT=9002

# Optional
GAJA_LOCATION_NAME=Gaja camp perimeter
